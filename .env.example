# Slack App Tokens
# Get these from https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Groq API Key (FREE — no credit card needed)
# Get from https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# SlackScope Configuration
# Comma-separated channel IDs to monitor (e.g., C01ABC123,C02DEF456)
MONITORED_CHANNELS=
# Channel ID where daily reports are posted
REPORT_CHANNEL=
# Time for daily report in HH:MM format (24h, UTC)
DAILY_REPORT_TIME=09:00
